{% macro input(type = 'text', id, label, required = false, value = '', error = '') %}
  <div class="mb-3">
    <label for="{{ id }}" class="form-label">
      {{ label }}
    </label>

    <input 
      type="{{ type }}"
      id="{{ id }}"
      name="{{ id }}"
      required="{{ required }}"
      value="{{ value }}"
      class="form-control"
    >

    {% if error is defined and error is not empty %}
      <span class="text-danger">{{ error }}</span>
    {% endif %}
  </div>
{% endmacro %}